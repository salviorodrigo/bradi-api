{
    "name": "salviorodrigo/bradi-nfe-api",
    "description": "This is a module of Bradi software responsible to work with brazilian invoices (NFe and NFCe)",
    "type": "project",
    
    "autoload": {
        "psr-4": {
            "BradiNfeApi\\": [ "src/" ]
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BradiNfeApi\\Tests\\": [ "tests/" ]
        }
    },
    "scripts": {
        "lint": "./vendor/bin/duster lint",
        "lint:fix": "./vendor/bin/duster fix",
        "test": "./vendor/bin/pest",
        "test:dirty": "./vendor/bin/pest --dirty",
        "test:ci": "./vendor/bin/pest --parallel"
    },
    "authors": [
        {
            "name": "Rodrigo Salvio"
        }
    ],
    "require": {
        "php": ">=8.4",
        "oittaa/uuid": "^1.10"
    },
    "require-dev": {
        "pestphp/pest": "^4.0",
        "tightenco/duster": "^3.1",
        "mockery/mockery": "^1.6",
        "symfony/var-dumper": "^8.0"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
