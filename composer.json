{
    "name": "salviorodrigo/bradi-nfe-api",
    "description": "This is a module of Bradi software responsible to work with brazilian invoices (NFe and NFCe)",
    "type": "project",
    
    "autoload": {
        "psr-4": {
            "BradiNfeApi\\": [ "src/" ]
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BradiNfeApi\\Tests\\": [ "tests/" ]
        }
    },
    "scripts": {
        "lint": "./vendor/bin/duster lint",
        "lint:dirty": "./vendor/bin/duster lint --dirty",
        "lint:fix": "./vendor/bin/duster fix",
        "test": "XDEBUG_MODE=off ./vendor/bin/pest",
        "test:ci": "XDEBUG_MODE=off ./vendor/bin/pest --parallel",
        "test:coverage": "XDEBUG_MODE=coverage php -d memory_limit=1024M ./vendor/bin/pest --coverage --coverage-html=./.coverage",
        "test:debug": "XDEBUG_TRIGGER=true ./vendor/bin/pest",
        "test:dirty": "XDEBUG_MODE=off ./vendor/bin/pest --dirty",
        "test:coverage-quick": "./vendor/bin/pest --type-coverage"
    },
    "authors": [
        {
            "name": "Rodrigo Salvio"
        }
    ],
    "require": {
        "php": ">=8.4",
        "oittaa/uuid": "~1.10"
    },
    "require-dev": {
        "pestphp/pest": "~4.0",
        "tightenco/duster": "~3.1",
        "mockery/mockery": "~1.6",
        "symfony/var-dumper": "~8.0",
        "phpro/grumphp": "~2.0",
        "pestphp/pest-plugin-type-coverage": "^4.0"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpro/grumphp": true
        }
    }
}
