{
	"$schema": "https://json-schema.org/draft/2019-09/schema",
	"name": "PHP",
	"build": {
		"dockerfile": "Dockerfile",
		"context": ".."
	},
	"mounts": [
		"source=${localEnv:HOME}/.gitconfig,target=/home/vscode/.gitconfig,type=bind,consistency=cached",
		"source=${localEnv:HOME}/.ssh,target=/tmp/host-ssh,type=bind,readonly"
	],
	"features": {
		"ghcr.io/devcontainers/features/node:1": {
			"version": "lts"
		}
	},
	"forwardPorts": [8080],
	"customizations": {
		"vscode": {
		"extensions": [
			"devsense.composer-php-vscode",
			"xdebug.php-debug",
			"bmewburn.vscode-intelephense-client",
			"mehedidracula.php-namespace-resolver"
			]
		}
	},
	"postCreateCommand": "sudo chown -R $(whoami) . && .devcontainer/setup-git-credentials.sh && composer install --no-interaction && composer dump-autoload --optimize && .devcontainer/setup-grumphp-hooks.sh",
	"postStartCommand": ".devcontainer/setup-git-credentials.sh && .devcontainer/setup-grumphp-hooks.sh"
	
}
