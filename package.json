{
  "type": "module",
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11"
  },
  "scripts": {
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*.php*": [
      "php ./vendor/bin/duster lint --using=tlint,phpcsfixer,pint",
      "php ./vendor/bin/pest"
    ]
  }
}
